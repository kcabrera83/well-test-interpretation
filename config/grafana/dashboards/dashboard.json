{
    "dashboard":  {
                      "id":  null,
                      "time":  {
                                   "to":  "now",
                                   "from":  "now-1h"
                               },
                      "title":  "well-test-interpretation Monitoring Dashboard",
                      "tags":  [
                                   "fastapi",
                                   "prometheus"
                               ],
                      "timezone":  "browser",
                      "refresh":  "10s",
                      "schemaVersion":  39,
                      "panels":  [
                                     {
                                         "gridPos":  {
                                                         "y":  0,
                                                         "w":  12,
                                                         "x":  0,
                                                         "h":  8
                                                     },
                                         "title":  "HTTP Requests",
                                         "id":  1,
                                         "type":  "graph",
                                         "targets":  [
                                                         {
                                                             "legendFormat":  "{{method}} {{handler}} {{status}}",
                                                             "expr":  "rate(http_requests_total[5m])"
                                                         }
                                                     ]
                                     },
                                     {
                                         "gridPos":  {
                                                         "y":  0,
                                                         "w":  12,
                                                         "x":  12,
                                                         "h":  8
                                                     },
                                         "title":  "Request Duration",
                                         "id":  2,
                                         "type":  "graph",
                                         "targets":  [
                                                         {
                                                             "legendFormat":  "p95 {{handler}}",
                                                             "expr":  "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))"
                                                         }
                                                     ]
                                     },
                                     {
                                         "gridPos":  {
                                                         "y":  8,
                                                         "w":  12,
                                                         "x":  0,
                                                         "h":  8
                                                     },
                                         "title":  "Request Count by Status",
                                         "id":  3,
                                         "type":  "stat",
                                         "targets":  [
                                                         {
                                                             "legendFormat":  "{{status}}",
                                                             "expr":  "sum(rate(http_requests_total[5m])) by (status)"
                                                         }
                                                     ]
                                     },
                                     {
                                         "gridPos":  {
                                                         "y":  8,
                                                         "w":  12,
                                                         "x":  12,
                                                         "h":  8
                                                     },
                                         "title":  "Active Requests",
                                         "id":  4,
                                         "type":  "gauge",
                                         "targets":  [
                                                         {
                                                             "legendFormat":  "{{handler}}",
                                                             "expr":  "http_requests_in_progress"
                                                         }
                                                     ]
                                     }
                                 ]
                  },
    "overwrite":  true
}
